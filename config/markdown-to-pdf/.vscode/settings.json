{
  "files.eol": "\n",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "always",
    "source.organizeImports": "always"
  },
  "python.analysis.autoImportCompletions": true,
  "python.analysis.extraPaths": [
    "${workspaceFolder:markdown-to-pdf}/types"
  ],
  "python.defaultInterpreterPath": "${workspaceFolder:markdown-to-pdf}/.venv/bin/python",
  "[python]": {
    "editor.codeActionsOnSave": {
      "source.fixAll": "always",
      "source.organizeImports": "always"
    },
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": true
  },
  "black-formatter.args": [
    "--config=${workspaceFolder:markdown-to-pdf}/pyproject.toml"
  ],
  "python.testing.pytestEnabled": true,
  "ruff.codeAction.disableRuleComment": {
    "enable": true
  },
  "ruff.codeAction.fixViolation": {
    "enable": true
  },
  "python.analysis.typeCheckingMode": "strict",
  "[lua]": {
    "editor.defaultFormatter": "JohnnyMorganz.stylua",
    "editor.formatOnSave": true
  },
  "stylua.configPath": "${workspaceFolder:markdown-to-pdf}/stylua.toml",
  "Lua.runtime.version": "Lua 5.4",
  "Lua.workspace.library": [
    "${workspaceFolder:markdown-to-pdf}/types"
  ],
  "Lua.diagnostics.unusedLocalExclude": [
    "_*"
  ],
  "cSpell.words": [
    "arraybackslash",
    "booktabs",
    "bottomrule",
    "colspec",
    "colspecs",
    "documentclass",
    "gantt",
    "includegraphics",
    "Inlines",
    "lstinline",
    "Luacheck",
    "mati",
    "midrule",
    "mmdc",
    "newpage",
    "pandoc",
    "pdflatex",
    "pytinytex",
    "raggedleft",
    "raggedright",
    "rtype",
    "tableofcontents",
    "tabularx",
    "textasciicircum",
    "textasciitilde",
    "textbackslash",
    "textbf",
    "textheight",
    "textunderscore",
    "textwidth",
    "tinytex",
    "toprule"
  ]
}