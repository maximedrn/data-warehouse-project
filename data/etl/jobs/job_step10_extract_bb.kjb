<?xml version="1.0" encoding="UTF-8"?>
<job>
  <name>job_step10_extract_bb</name>
  <description>Extraction and reconceptualization of the BuckBoaster source</description>
  <extended_description/>
  <job_version>1</job_version>
  <entries>
    <entry>
      <name>START</name>
      <type>SPECIAL</type>
      <start>Y</start>
      <repeat>N</repeat>
      <schedulerType>0</schedulerType>
      <GUI>
        <xloc>50</xloc>
        <yloc>50</yloc>
      </GUI>
    </entry>
    <entry>
      <name>Extract bb_movie</name>
      <type>TRANS</type>
      <filename>${ETL_HOME}/transformations/transform_extract_bb_movie.ktr</filename>
      <run_configuration>local</run_configuration>
      <GUI>
        <xloc>200</xloc>
        <yloc>50</yloc>
      </GUI>
    </entry>
    <entry>
      <name>Extract bb_actor</name>
      <type>TRANS</type>
      <filename>${ETL_HOME}/transformations/transform_extract_bb_actor.ktr</filename>
      <run_configuration>local</run_configuration>
      <GUI>
        <xloc>350</xloc>
        <yloc>50</yloc>
      </GUI>
    </entry>
    <entry>
      <name>Extract bb_appears_in</name>
      <type>TRANS</type>
      <filename>${ETL_HOME}/transformations/transform_extract_bb_appears_in.ktr</filename>
      <run_configuration>local</run_configuration>
      <GUI>
        <xloc>500</xloc>
        <yloc>50</yloc>
      </GUI>
    </entry>
    <entry>
      <name>Extract bb_client (dedup)</name>
      <type>TRANS</type>
      <filename>${ETL_HOME}/transformations/transform_extract_bb_client.ktr</filename>
      <run_configuration>local</run_configuration>
      <GUI>
        <xloc>200</xloc>
        <yloc>150</yloc>
      </GUI>
    </entry>
    <entry>
      <name>Extract bb_movie_sale</name>
      <type>TRANS</type>
      <filename>${ETL_HOME}/transformations/transform_extract_bb_movie_sale.ktr</filename>
      <run_configuration>local</run_configuration>
      <GUI>
        <xloc>350</xloc>
        <yloc>150</yloc>
      </GUI>
    </entry>
    <entry>
      <name>Extract bb_gadget_sale</name>
      <type>TRANS</type>
      <filename>${ETL_HOME}/transformations/transform_extract_bb_gadget_sale.ktr</filename>
      <run_configuration>local</run_configuration>
      <GUI>
        <xloc>500</xloc>
        <yloc>150</yloc>
      </GUI>
    </entry>
    <entry>
      <name>SUCCESS</name>
      <type>SPECIAL</type>
      <start>N</start>
      <dummy>N</dummy>
      <GUI>
        <xloc>650</xloc>
        <yloc>150</yloc>
      </GUI>
    </entry>
  </entries>
  <hops>
    <hop>
      <from>START</from>
      <to>Extract bb_movie</to>
      <enabled>Y</enabled>
      <evaluation>Y</evaluation>
    </hop>
    <hop>
      <from>Extract bb_movie</from>
      <to>Extract bb_actor</to>
      <enabled>Y</enabled>
      <evaluation>Y</evaluation>
    </hop>
    <hop>
      <from>Extract bb_actor</from>
      <to>Extract bb_appears_in</to>
      <enabled>Y</enabled>
      <evaluation>Y</evaluation>
    </hop>
    <hop>
      <from>Extract bb_appears_in</from>
      <to>Extract bb_client (dedup)</to>
      <enabled>Y</enabled>
      <evaluation>Y</evaluation>
    </hop>
    <hop>
      <from>Extract bb_client (dedup)</from>
      <to>Extract bb_movie_sale</to>
      <enabled>Y</enabled>
      <evaluation>Y</evaluation>
    </hop>
    <hop>
      <from>Extract bb_movie_sale</from>
      <to>Extract bb_gadget_sale</to>
      <enabled>Y</enabled>
      <evaluation>Y</evaluation>
    </hop>
    <hop>
      <from>Extract bb_gadget_sale</from>
      <to>SUCCESS</to>
      <enabled>Y</enabled>
      <evaluation>Y</evaluation>
    </hop>
  </hops>
</job>