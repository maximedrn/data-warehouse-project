<?xml version="1.0" encoding="UTF-8"?>
<!--
  Job : job_extract_bb
  Source : BuckBoaster (db_bb)
  Purpose : Extract and re-conceptualize every entity from the BuckBoaster 
    Access database into the re-conceptualized schema db_bb.

  Step order (sequential, each must succeed before the next starts):
    1. Extract bb_movie — strip T-prefix on movie_id/title
    2. Extract bb_actor — strip T-prefix on actor_id/name
    3. Extract bb_appears_in — resolve FK
    4. Extract bb_client — T-prefix cleanup + de-duplicate on
    5. Extract bb_movie_sale — sale_item WHERE sale_price IS NOT NULL
    6. Extract bb_gadget_sale  — gadget table, strip T-prefix on type/title
-->
<job>
  <name>job_extract_bb</name>
  <description>Extraction and re-conceptualization of the BuckBoaster source</description>
  <extended_description>Populates db_bb from the raw Access data loaded by mdb-loader.
    All T-prefixed strings are stripped. Clients are deduplicated on (prenom, nom, date_naissance).</extended_description>
  <job_version>1</job_version>
  <entries>
    <entry>
      <name>START</name>
      <type>SPECIAL</type>
      <start>Y</start>
      <repeat>N</repeat>
      <schedulerType>0</schedulerType>
      <GUI>
        <xloc>50</xloc>
        <yloc>50</yloc>
      </GUI>
    </entry>
    <!-- Step 1: movies — strip leading 'T' from movie_id and movie_title -->
    <entry>
      <name>Extract bb_movie</name>
      <type>TRANS</type>
      <filename>${ETL_HOME}/transforms/transform_extract_bb_movie.ktr</filename>
      <run_configuration>local</run_configuration>
      <GUI>
        <xloc>200</xloc>
        <yloc>50</yloc>
      </GUI>
    </entry>
    <!-- Step 2: actors — strip leading 'T' from actor_id and name -->
    <entry>
      <name>Extract bb_actor</name>
      <type>TRANS</type>
      <filename>${ETL_HOME}/transforms/transform_extract_bb_actor.ktr</filename>
      <run_configuration>local</run_configuration>
      <GUI>
        <xloc>350</xloc>
        <yloc>50</yloc>
      </GUI>
    </entry>
    <!-- Step 3: movie-actor associations — relies on bb_film and bb_acteur -->
    <entry>
      <name>Extract bb_appears_in</name>
      <type>TRANS</type>
      <filename>${ETL_HOME}/transforms/transform_extract_bb_appears_in.ktr</filename>
      <run_configuration>local</run_configuration>
      <GUI>
        <xloc>500</xloc>
        <yloc>50</yloc>
      </GUI>
    </entry>
    <!-- 
      Step 4: clients — dedup on (prenom, nom, date_naissance); 
      ~20% duplicate rows in source
    -->
    <entry>
      <name>Extract bb_client (dedup)</name>
      <type>TRANS</type>
      <filename>${ETL_HOME}/transforms/transform_extract_buckboaster_customer.ktr</filename>
      <run_configuration>local</run_configuration>
      <GUI>
        <xloc>200</xloc>
        <yloc>150</yloc>
      </GUI>
    </entry>
    <!-- Step 5: film sales — only rows with sale_price IS NOT NULL -->
    <entry>
      <name>Extract bb_movie_sale</name>
      <type>TRANS</type>
      <filename>${ETL_HOME}/transforms/transform_extract_bb_movie_sale.ktr</filename>
      <run_configuration>local</run_configuration>
      <GUI>
        <xloc>350</xloc>
        <yloc>150</yloc>
      </GUI>
    </entry>
    <!-- 
      Step 6: gadget sales — full table, T-prefix stripped on type and title 
    -->
    <entry>
      <name>Extract bb_gadget_sale</name>
      <type>TRANS</type>
      <filename>${ETL_HOME}/transforms/transform_extract_bb_gadget_sale.ktr</filename>
      <run_configuration>local</run_configuration>
      <GUI>
        <xloc>500</xloc>
        <yloc>150</yloc>
      </GUI>
    </entry>
    <entry>
      <name>SUCCESS</name>
      <type>SPECIAL</type>
      <start>N</start>
      <dummy>N</dummy>
      <GUI>
        <xloc>650</xloc>
        <yloc>150</yloc>
      </GUI>
    </entry>
  </entries>
  <hops>
    <hop>
      <from>START</from>
      <to>Extract bb_movie</to>
      <enabled>Y</enabled>
      <evaluation>Y</evaluation>
    </hop>
    <hop>
      <from>Extract bb_movie</from>
      <to>Extract bb_actor</to>
      <enabled>Y</enabled>
      <evaluation>Y</evaluation>
    </hop>
    <hop>
      <from>Extract bb_actor</from>
      <to>Extract bb_appears_in</to>
      <enabled>Y</enabled>
      <evaluation>Y</evaluation>
    </hop>
    <hop>
      <from>Extract bb_appears_in</from>
      <to>Extract bb_client (dedup)</to>
      <enabled>Y</enabled>
      <evaluation>Y</evaluation>
    </hop>
    <hop>
      <from>Extract bb_client (dedup)</from>
      <to>Extract bb_movie_sale</to>
      <enabled>Y</enabled>
      <evaluation>Y</evaluation>
    </hop>
    <hop>
      <from>Extract bb_movie_sale</from>
      <to>Extract bb_gadget_sale</to>
      <enabled>Y</enabled>
      <evaluation>Y</evaluation>
    </hop>
    <hop>
      <from>Extract bb_gadget_sale</from>
      <to>SUCCESS</to>
      <enabled>Y</enabled>
      <evaluation>Y</evaluation>
    </hop>
  </hops>
</job>