<?xml version="1.0" encoding="UTF-8"?>
<!--
  Mondrian OLAP Schema : MoreMovies
  File    : data/olap/moremovies.xml
  Engine  : Mondrian 4 (via Pentaho Server 9.4)
  Database: db_rolap  (MySQL 9)

  Overview
  ────────
  Two cubes share four conformed dimensions:
    Sales   — fact table fait_ventes   (partitioned by year 2005-2012)
    Rentals — fact table fait_locations (partitioned by year 2005-2012)

  Conformed dimensions (shared across both cubes):
    Time    — Day → Month → Quarter → Year  (dim_temps)
    Product — Type → Subtype → Product      (dim_produit)
    Store   — Store                         (dim_magasin)
    Client  — hierarchy "By Age Group": Age Group → Client
              hierarchy "By Gender":    Gender → Client

  Aggregate tables (Mondrian AggName — query rewriting):
    agg_ventes_mois_magasin          → Sales cube, Store + Time[Month/Year]
    agg_ventes_mois_produit          → Sales cube, Product + Time[Month/Year]
    agg_locations_mois_produit_magasin → Rentals cube, Product + Store + Time

  Calculated members:
    Sales   : Avg Revenue per Sale  = Revenue / Nb Sales
              Margin Rate           = Gross Margin / Revenue
    Rentals : Avg Revenue per Rental = Rental Revenue / Nb Rentals
              Avg Duration (days)    = Total Days / Nb Rentals
-->
<Schema name="MoreMovies">

  <!-- ═══════════════════════════════════════════════════════════════════════
       SHARED DIMENSIONS
  ════════════════════════════════════════════════════════════════════════════ -->

  <!--
    Time dimension
    Hierarchy: Year → Quarter → Month → Day
    levelType attributes enable time-intelligence functions (YTD, QTD, etc.).
    Quarter caption uses CONCAT to display "Q1", "Q2", etc.
    Month ordered by the numeric mois column (not alphabetically by nom_mois).
  -->
  <Dimension name="Time" type="TimeDimension">
    <Hierarchy hasAll="true" allMemberName="All Periods" primaryKey="temps_id">
      <Table name="dim_temps"/>
      <Level name="Year"    column="annee"    type="Numeric" levelType="TimeYears"
        uniqueMembers="true"/>
      <Level name="Quarter" column="trimestre" type="Numeric" levelType="TimeQuarters"
        uniqueMembers="false" nameColumn="trimestre"
        captionExpression="CONCAT('Q', `dim_temps`.`trimestre`)"/>
      <Level name="Month"   column="mois"     type="Numeric" levelType="TimeMonths"
        uniqueMembers="false" nameColumn="nom_mois" ordinalColumn="mois"/>
      <Level name="Day"     column="jour"     type="Numeric" levelType="TimeDays"
        uniqueMembers="false"/>
    </Hierarchy>
  </Dimension>

  <!--
    Product dimension
    Hierarchy: All Products → Type (film/gadget) → Subtype → Product
    produit_id is the unique key; titre is used as the display name.
  -->
  <Dimension name="Product">
    <Hierarchy hasAll="true" allMemberName="All Products" primaryKey="produit_id">
      <Table name="dim_produit"/>
      <Level name="Type"    column="type"      type="String"  uniqueMembers="true"/>
      <Level name="Subtype" column="sous_type"  type="String"  uniqueMembers="false"/>
      <Level name="Product" column="produit_id" type="Numeric" uniqueMembers="true"
        nameColumn="titre"/>
    </Hierarchy>
  </Dimension>

  <!--
    Store dimension
    Single-level hierarchy (no geographic rollup).
    magasin_id is the key; nom is used as the display name.
  -->
  <Dimension name="Store">
    <Hierarchy hasAll="true" allMemberName="All Stores" primaryKey="magasin_id">
      <Table name="dim_magasin"/>
      <Level name="Store" column="magasin_id" type="Numeric" uniqueMembers="true"
        nameColumn="nom"/>
    </Hierarchy>
  </Dimension>

  <!--
    Client dimension — two independent hierarchies on the same table.

    "By Age Group": All Clients → Age Group → Client
      tranche_age buckets: '<25', '25-40', '40-60', '>60', 'Unknown'
      Caption shows "Firstname Lastname" (CONCAT on prenom + nom).

    "By Gender": All Clients → Gender (M/F) → Client
  -->
  <Dimension name="Client">
    <Hierarchy name="By Age Group" hasAll="true" allMemberName="All Clients"
      primaryKey="client_id">
      <Table name="dim_client"/>
      <Level name="Age Group" column="tranche_age" type="String" uniqueMembers="true"/>
      <Level name="Client"    column="client_id"   type="Numeric" uniqueMembers="true"
        nameColumn="nom"
        captionExpression="CONCAT(`dim_client`.`prenom`, ' ', `dim_client`.`nom`)"/>
    </Hierarchy>
    <Hierarchy name="By Gender" hasAll="true" allMemberName="All Clients"
      primaryKey="client_id">
      <Table name="dim_client"/>
      <Level name="Gender" column="genre"     type="String"  uniqueMembers="true"/>
      <Level name="Client" column="client_id" type="Numeric" uniqueMembers="true"
        nameColumn="nom"/>
    </Hierarchy>
  </Dimension>

  <!-- ═══════════════════════════════════════════════════════════════════════
       SALES CUBE  —  fait_ventes
  ════════════════════════════════════════════════════════════════════════════ -->
  <!--
    Measures:
      Sales Revenue        — SUM(ca_ventes)
      Inventory Cost       — SUM(prix_inventaire_total)
      Gross Margin         — SUM(marge)  [generated column = ca_ventes - prix_inventaire_total]
      Number of Sales      — SUM(nb_ventes)
    Calculated:
      Avg Revenue per Sale — Revenue / Nb Sales
      Margin Rate          — Gross Margin / Revenue  (formatted as %)

    Aggregate tables declared for Mondrian query rewriting:
      agg_ventes_mois_magasin  → Store × Month/Year grain
      agg_ventes_mois_produit  → Product × Month/Year grain
  -->
  <Cube name="Sales" defaultMeasure="Sales Revenue">
    <Table name="fait_ventes"/>
    <DimensionUsage name="Time"    source="Time"    foreignKey="temps_id"/>
    <DimensionUsage name="Product" source="Product" foreignKey="produit_id"/>
    <DimensionUsage name="Store"   source="Store"   foreignKey="magasin_id"/>
    <DimensionUsage name="Client"  source="Client"  foreignKey="client_id"/>

    <Measure name="Sales Revenue"   column="ca_ventes"             aggregator="sum"
      formatString="#,##0.00 €" datatype="Numeric"/>
    <Measure name="Inventory Cost"  column="prix_inventaire_total"  aggregator="sum"
      formatString="#,##0.00 €" datatype="Numeric"/>
    <!-- marge is a GENERATED ALWAYS column in fait_ventes (ca_ventes - prix_inventaire_total) -->
    <Measure name="Gross Margin"    column="marge"                  aggregator="sum"
      formatString="#,##0.00 €" datatype="Numeric"/>
    <Measure name="Number of Sales" column="nb_ventes"              aggregator="sum"
      formatString="#,##0" datatype="Integer"/>

    <CalculatedMember name="Avg Revenue per Sale" dimension="Measures"
      formula="[Measures].[Sales Revenue] / [Measures].[Number of Sales]"
      formatString="#,##0.00 €"/>
    <CalculatedMember name="Margin Rate" dimension="Measures"
      formula="[Measures].[Gross Margin] / [Measures].[Sales Revenue]"
      formatString="0.0%"/>

    <!-- Aggregate: Store × Month/Year — answers Q2 (monthly revenue by store) -->
    <AggName name="agg_ventes_mois_magasin">
      <AggFactCount column="nb_ventes"/>
      <AggMeasure name="[Measures].[Sales Revenue]"  column="ca_total"/>
      <AggMeasure name="[Measures].[Gross Margin]"   column="marge_totale"/>
      <AggMeasure name="[Measures].[Number of Sales]" column="nb_ventes"/>
      <AggLevel name="[Time].[Year]"   column="annee"/>
      <AggLevel name="[Time].[Month]"  column="mois"/>
      <AggLevel name="[Store].[Store]" column="magasin_id"/>
    </AggName>

    <!-- Aggregate: Product × Month/Year — answers Q1 (top movies by monthly revenue) -->
    <AggName name="agg_ventes_mois_produit">
      <AggFactCount column="nb_ventes"/>
      <AggMeasure name="[Measures].[Sales Revenue]"  column="ca_total"/>
      <AggMeasure name="[Measures].[Number of Sales]" column="nb_ventes"/>
      <AggLevel name="[Time].[Year]"        column="annee"/>
      <AggLevel name="[Time].[Month]"       column="mois"/>
      <AggLevel name="[Product].[Product]"  column="produit_id"/>
      <AggLevel name="[Product].[Type]"     column="type_produit"/>
    </AggName>
  </Cube>

  <!-- ═══════════════════════════════════════════════════════════════════════
       RENTALS CUBE  —  fait_locations
  ════════════════════════════════════════════════════════════════════════════ -->
  <!--
    Source: MetroStarlet + MovieMegaMart only (BuckBoaster has no rental activity).

    Measures:
      Rental Revenue     — SUM(ca_locations)  [= prix_jour × nb_jours]
      Number of Rentals  — SUM(nb_locations)
      Total Rental Days  — SUM(nb_jours_total)
    Calculated:
      Avg Revenue per Rental — Rental Revenue / Nb Rentals
      Avg Duration (days)    — Total Days / Nb Rentals

    Aggregate table declared for Mondrian query rewriting:
      agg_locations_mois_produit_magasin → Product × Store × Month/Year grain
      Answers Q4 (most rented movies by store) and Q5 (monthly rental trends).
  -->
  <Cube name="Rentals" defaultMeasure="Rental Revenue">
    <Table name="fait_locations"/>
    <DimensionUsage name="Time"    source="Time"    foreignKey="temps_id"/>
    <DimensionUsage name="Product" source="Product" foreignKey="produit_id"/>
    <DimensionUsage name="Store"   source="Store"   foreignKey="magasin_id"/>
    <DimensionUsage name="Client"  source="Client"  foreignKey="client_id"/>

    <Measure name="Rental Revenue"    column="ca_locations"  aggregator="sum"
      formatString="#,##0.00 €" datatype="Numeric"/>
    <Measure name="Number of Rentals" column="nb_locations"  aggregator="sum"
      formatString="#,##0" datatype="Integer"/>
    <Measure name="Total Rental Days" column="nb_jours_total" aggregator="sum"
      formatString="#,##0" datatype="Integer"/>

    <CalculatedMember name="Avg Revenue per Rental" dimension="Measures"
      formula="[Measures].[Rental Revenue] / [Measures].[Number of Rentals]"
      formatString="#,##0.00 €"/>
    <CalculatedMember name="Avg Duration (days)" dimension="Measures"
      formula="[Measures].[Total Rental Days] / [Measures].[Number of Rentals]"
      formatString="#,##0.0"/>

    <!-- Aggregate: Product × Store × Month/Year — answers Q4 and Q5 -->
    <AggName name="agg_locations_mois_produit_magasin">
      <AggFactCount column="nb_locations"/>
      <AggMeasure name="[Measures].[Rental Revenue]"    column="ca_total"/>
      <AggMeasure name="[Measures].[Number of Rentals]" column="nb_locations"/>
      <AggMeasure name="[Measures].[Total Rental Days]" column="nb_jours_total"/>
      <AggLevel name="[Time].[Year]"        column="annee"/>
      <AggLevel name="[Time].[Month]"       column="mois"/>
      <AggLevel name="[Product].[Product]"  column="produit_id"/>
      <AggLevel name="[Store].[Store]"      column="magasin_id"/>
    </AggName>
  </Cube>

</Schema>
